<UserControl
    x:Class="WinUiFileManager.Presentation.Views.SinglePanelView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:fileEntryTable="using:WinUiFileManager.Presentation.FileEntryTable"
    xmlns:i="using:Microsoft.Xaml.Interactivity">

    <Border x:Name="PanelBorder"
            BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="1"
            Padding="4">
        <i:Interaction.Behaviors>
            <i:DataTriggerBehavior Binding="{x:Bind ViewModel.IsActive, Mode=OneWay}" Value="True">
                <i:ChangePropertyAction PropertyName="BorderBrush"
                                        TargetObject="{Binding ElementName=PanelBorder}"
                                        Value="{ThemeResource SystemControlForegroundAccentBrush}" />
                <i:ChangePropertyAction PropertyName="BorderThickness"
                                        TargetObject="{Binding ElementName=PanelBorder}"
                                        Value="2" />
            </i:DataTriggerBehavior>
            <i:DataTriggerBehavior Binding="{x:Bind ViewModel.IsActive, Mode=OneWay}" Value="False">
                <i:ChangePropertyAction PropertyName="BorderBrush"
                                        TargetObject="{Binding ElementName=PanelBorder}"
                                        Value="{ThemeResource SystemControlForegroundBaseLowBrush}" />
                <i:ChangePropertyAction PropertyName="BorderThickness"
                                        TargetObject="{Binding ElementName=PanelBorder}"
                                        Value="1" />
            </i:DataTriggerBehavior>
        </i:Interaction.Behaviors>
        <Grid RowSpacing="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" ColumnSpacing="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="104" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="DrivePicker"
                          Grid.Column="0"
                          HorizontalAlignment="Stretch"
                          DisplayMemberPath="DriveLetter"
                          ItemsSource="{x:Bind AvailableVolumes, Mode=OneWay}"
                          SelectedItem="{x:Bind FindVolume(ViewModel.FileEntries.CurrentPath), Mode=OneWay}"
                          SelectionChanged="OnDriveSelectionChanged" />
                <TextBox x:Name="PathBox"
                         Grid.Column="1"
                         Text="{x:Bind ViewModel.FileEntries.EditablePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         ToolTipService.ToolTip="{x:Bind ViewModel.FileEntries.PathValidationMessage, Mode=OneWay}"
                         KeyDown="OnPathTextBoxKeyDown" />
            </Grid>
            <fileEntryTable:SpecFileEntryTableView x:Name="EntryTable"
                                                   Grid.Row="1"
                                                   CurrentFolder="{x:Bind ViewModel.FileEntries.CurrentPath, Mode=OneWay}"
                                                   ItemsSource="{x:Bind ViewModel.FileEntries.Items, Mode=OneWay}" />
            <Border Grid.Row="2"
                    Height="24"
                    Padding="8,0"
                    VerticalAlignment="Stretch"
                    Background="{ThemeResource SystemControlBackgroundAltHighBrush}">
                <TextBlock VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}">
                    <Run Text="{x:Bind ViewModel.FileEntries.Items.Count, Mode=OneWay}" />
                    <Run Text=" items, " />
                    <Run Text="{x:Bind ViewModel.SelectedCount, Mode=OneWay}" />
                    <Run Text=" selected" />
                </TextBlock>
            </Border>
        </Grid>
    </Border>
</UserControl>
