<UserControl
    x:Class="WinUiFileManager.Presentation.Controls.FileInspectorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:viewModels="using:WinUiFileManager.Presentation.ViewModels">

    <UserControl.Resources>
        <converters:CollectionVisibilityConverter x:Key="CollectionVisibilityConverter" />
        <Style x:Key="InspectorCellStyle" TargetType="TextBlock">
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="IsTextSelectionEnabled" Value="True" />
        </Style>
    </UserControl.Resources>

    <Border Padding="12"
            BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
            BorderThickness="1"
            Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid x:Name="InspectorContentGrid"
              RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="2"
                       Text="No files selected"
                       Visibility="{x:Bind ViewModel.SelectedItems, Mode=OneWay, Converter={StaticResource CollectionVisibilityConverter}, ConverterParameter=True}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       TextAlignment="Center"
                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />

            
            <Grid Grid.Row="0" ColumnSpacing="8" 
                  Visibility="{x:Bind ViewModel.SelectedItems, Mode=OneWay, Converter={StaticResource CollectionVisibilityConverter}, ConverterParameter=False}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Inspector"
                           FontSize="18"
                           FontWeight="SemiBold" />

                <Button Grid.Column="1"
                        Content="Refresh"
                        Click="OnRefreshClick" />

                <Button Grid.Column="2"
                        Content="Properties"
                        Click="OnPropertiesClick" />

                <Button Grid.Column="3"
                        Content="Copy All"
                        Click="OnCopyAllClick" />
            </Grid>

            <TextBox Grid.Row="1"
                     x:Name="SearchBox"
                     PlaceholderText="Search property or value"
                     Text="{x:Bind ViewModel.SearchText, Mode=OneWay}"
                     TextChanged="OnSearchTextChanged" />

            <ScrollViewer Grid.Row="2"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalAlignment="Stretch">
                <ItemsRepeater ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="8" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:FileInspectorCategoryViewModel">
                            <Expander Header="{x:Bind Name, Mode=OneWay}"
                                      Visibility="{x:Bind Visibility, Mode=OneWay}"
                                      IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}"
                                      HorizontalAlignment="Stretch"
                                      HorizontalContentAlignment="Stretch">
                                <Border BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        HorizontalAlignment="Stretch">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0"
                                              Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="180" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    Padding="16,10"
                                                    BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                                                    BorderThickness="0,0,1,1">
                                                <TextBlock Text="Property"
                                                           FontWeight="SemiBold" />
                                            </Border>

                                            <Border Grid.Column="1"
                                                    Padding="16,10"
                                                    BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                                                    BorderThickness="0,0,0,1">
                                                <TextBlock Text="Value"
                                                           FontWeight="SemiBold" />
                                            </Border>
                                        </Grid>

                                        <ItemsRepeater Grid.Row="1"
                                                       ItemsSource="{x:Bind Fields, Mode=OneWay}">
                                            <ItemsRepeater.Layout>
                                                <StackLayout />
                                            </ItemsRepeater.Layout>
                                            <ItemsRepeater.ItemTemplate>
                                                <DataTemplate x:DataType="viewModels:FileInspectorFieldViewModel">
                                                    <Grid Visibility="{x:Bind RowVisibility, Mode=OneWay}">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="180" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>

                                                        <Border Grid.Column="0"
                                                                Padding="16,10"
                                                                BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                                                                BorderThickness="0,0,1,1"
                                                                Background="Transparent"
                                                                ToolTipService.ToolTip="{x:Bind Tooltip, Mode=OneWay}">
                                                            <TextBlock Text="{x:Bind Key, Mode=OneWay}"
                                                                       Style="{StaticResource InspectorCellStyle}" />
                                                        </Border>

                                                        <Border Grid.Column="1"
                                                                Padding="16,10"
                                                                BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                                                                BorderThickness="0,0,0,1"
                                                                Background="Transparent">
                                                            <Grid ColumnSpacing="12">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>

                                                                <Grid Grid.Column="0">
                                                                    <ProgressRing Width="14"
                                                                                  Height="14"
                                                                                  IsActive="True"
                                                                                  HorizontalAlignment="Left"
                                                                                  VerticalAlignment="Center"
                                                                                  Visibility="{x:Bind LoadingVisibility, Mode=OneWay}" />
                                                                    <TextBlock Text="{x:Bind DisplayValue, Mode=OneWay}"
                                                                               Style="{StaticResource InspectorCellStyle}"
                                                                               Visibility="{x:Bind ValueVisibility, Mode=OneWay}" />
                                                                    <Border Width="30"
                                                                            Height="30"
                                                                            Padding="0"
                                                                            Margin="0"
                                                                            HorizontalAlignment="Left"
                                                                            VerticalAlignment="Center"
                                                                            Visibility="{x:Bind ThumbnailVisibility, Mode=OneWay}">
                                                                        <Image Source="{x:Bind ThumbnailSource, Mode=OneWay}"
                                                                               Width="30"
                                                                               Height="30"
                                                                               HorizontalAlignment="Stretch"
                                                                               VerticalAlignment="Stretch"
                                                                               Stretch="UniformToFill" />
                                                                    </Border>
                                                                </Grid>

                                                                <CheckBox Grid.Column="1"
                                                                          VerticalAlignment="Center"
                                                                          IsChecked="{x:Bind IsToggleOn, Mode=OneWay}"
                                                                          Command="{x:Bind ToggleCommand, Mode=OneWay}"
                                                                          Visibility="{x:Bind ToggleVisibility, Mode=OneWay}" />
                                                            </Grid>
                                                        </Border>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsRepeater.ItemTemplate>
                                        </ItemsRepeater>
                                    </Grid>
                                </Border>
                            </Expander>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>

        </Grid>
    </Border>
</UserControl>
