<Window
    x:Class="WinUiFileManager.TestApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:fileEntryTable="using:WinUiFileManager.Presentation.FileEntryTable"
    xmlns:keyboard="using:WinUiFileManager.Presentation.Keyboard"
    xmlns:messageLogging="using:WinUiFileManager.Presentation.MessageLogging"
    Title="FileEntry Table TestApp">
    <Grid
        x:Name="LayoutRoot"
        Padding="12"
        ColumnSpacing="12"
        keyboard:KeyboardInputBehavior.Command="{x:Bind KeyboardManager.KeyPressedCommand, Mode=OneWay}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420" />
            <ColumnDefinition Width="420" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid RowSpacing="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock
                FontWeight="SemiBold"
                Text="Left panel" />

            <TextBlock
                Grid.Row="1"
                Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                Text="C:\FileEntryTableTest\Left" />

            <fileEntryTable:SpecFileEntryTableView
                x:Name="LeftTable"
                Grid.Row="2"
                Identity="Left" />
        </Grid>

        <Grid
            Grid.Column="1"
            RowSpacing="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock
                FontWeight="SemiBold"
                Text="Right panel" />

            <TextBlock
                Grid.Row="1"
                Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                Text="C:\FileEntryTableTest\Right" />

            <fileEntryTable:SpecFileEntryTableView
                x:Name="RightTable"
                Grid.Row="2"
                Identity="Right" />
        </Grid>

        <messageLogging:MessageLogView Grid.Column="2" />
    </Grid>
</Window>
