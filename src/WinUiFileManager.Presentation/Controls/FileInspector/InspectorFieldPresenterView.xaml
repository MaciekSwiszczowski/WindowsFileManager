<UserControl
    x:Class="WinUiFileManager.Presentation.Controls.FileInspector.InspectorFieldPresenterView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:fields="using:WinUiFileManager.Presentation.ViewModels.Inspector.Fields"
    xmlns:fileInspector="using:WinUiFileManager.Presentation.Controls.FileInspector">

    <controls:SwitchPresenter TargetType="fields:InspectorFieldType"
                              HorizontalAlignment="Stretch"
                              Value="{x:Bind Field.FieldType, Mode=OneWay}">
        <controls:Case Value="Text">
            <fileInspector:InspectorTextFieldView Field="{x:Bind Field, Mode=OneWay}" />
        </controls:Case>
        <controls:Case Value="Thumbnail">
            <fileInspector:InspectorThumbnailFieldView Field="{x:Bind ThumbnailField, Mode=OneWay}" />
        </controls:Case>
        <controls:Case Value="Toggle">
            <fileInspector:InspectorToggleFieldView Field="{x:Bind ToggleField, Mode=OneWay}" />
        </controls:Case>
    </controls:SwitchPresenter>
</UserControl>
