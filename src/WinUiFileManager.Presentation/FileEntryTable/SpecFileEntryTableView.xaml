<UserControl
    x:Class="WinUiFileManager.Presentation.FileEntryTable.SpecFileEntryTableView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:fileEntryTable="using:WinUiFileManager.Presentation.FileEntryTable"
    xmlns:tv="using:WinUI.TableView"
    Loaded="FileEntryTableView_Loaded"
    GotFocus="FileEntryTableView_GotFocus"
    LostFocus="FileEntryTableView_LostFocus">
    <UserControl.Resources>
        <Style x:Key="EllipsisTextCellStyle" TargetType="TextBlock">
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="MutedEllipsisCellStyle" TargetType="TextBlock" BasedOn="{StaticResource EllipsisTextCellStyle}">
            <Setter Property="Foreground" Value="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
        </Style>
        <Style x:Key="RightAlignEllipsisCellStyle" TargetType="TextBlock" BasedOn="{StaticResource EllipsisTextCellStyle}">
            <Setter Property="HorizontalAlignment" Value="Right" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <tv:TableView
            x:Name="ParentTable"
            ItemsSource="{x:Bind ParentRows, Mode=OneWay}"
            AutoGenerateColumns="False"
            CanFilterColumns="False"
            CanReorderColumns="False"
            CornerButtonMode="None"
            FocusVisualPrimaryThickness="0"
            FocusVisualSecondaryThickness="0"
            HeadersVisibility="Columns"
            IsReadOnly="True"
            DoubleTapped="ParentTable_DoubleTapped"
            SelectionChanged="ParentTable_SelectionChanged"
            SelectionMode="Single"
            SelectionUnit="Row"
            ShowExportOptions="False"
            Sorting="Table_Sorting"
            UseSystemFocusVisuals="False"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
            ScrollViewer.HorizontalScrollMode="Disabled"
            ScrollViewer.VerticalScrollBarVisibility="Hidden"
            ScrollViewer.VerticalScrollMode="Disabled">
            <tv:TableView.Resources>
                <SolidColorBrush
                    x:Key="TableViewRowBackgroundSelected"
                    Color="{ThemeResource SystemAccentColor}"
                    Opacity="0.35" />
                <SolidColorBrush
                    x:Key="TableViewRowBackgroundSelectedPointerOver"
                    Color="{ThemeResource SystemAccentColor}"
                    Opacity="0.5" />
                <SolidColorBrush
                    x:Key="TableViewRowBackgroundSelectedPressed"
                    Color="{ThemeResource SystemAccentColor}"
                    Opacity="0.6" />
                <SolidColorBrush x:Key="TableViewRowFocusVisualPrimaryBrush" Color="Transparent" />
                <SolidColorBrush x:Key="TableViewRowFocusBorderBrush" Color="Transparent" />
            </tv:TableView.Resources>
            <tv:TableView.Columns>
                <tv:TableViewTemplateColumn Header="Name" SortMemberPath="Name" Width="320" MinWidth="100" CanSort="True">
                    <tv:TableViewTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="fileEntryTable:SpecFileEntryViewModel">
                            <TextBlock Text="{x:Bind Name, Mode=OneTime}" Style="{StaticResource EllipsisTextCellStyle}" />
                        </DataTemplate>
                    </tv:TableViewTemplateColumn.CellTemplate>
                </tv:TableViewTemplateColumn>
                <tv:TableViewTextColumn Header="Ext" SortMemberPath="Extension" Binding="{Binding Extension}" Width="40" MinWidth="32" ElementStyle="{StaticResource MutedEllipsisCellStyle}" CanSort="True" />
                <tv:TableViewTextColumn Header="Size" SortMemberPath="Size" Binding="{Binding Size}" Width="70" MinWidth="56" ElementStyle="{StaticResource RightAlignEllipsisCellStyle}" CanSort="True" />
                <tv:TableViewDateColumn Header="Modified" SortMemberPath="Modified" Binding="{Binding Modified}" DateFormat="yyyy-MM-dd HH:mm:ss" Width="120" MinWidth="100" ElementStyle="{StaticResource EllipsisTextCellStyle}" CanSort="True" />
                <tv:TableViewTextColumn Header="Attr" SortMemberPath="Attributes" Binding="{Binding Attributes}" Width="50" MinWidth="40" ElementStyle="{StaticResource MutedEllipsisCellStyle}" CanSort="True" />
            </tv:TableView.Columns>
        </tv:TableView>

        <tv:TableView
            x:Name="EntryTable"
            Grid.Row="1"
            ItemsSource="{x:Bind VisibleItems, Mode=OneWay}"
            AutoGenerateColumns="False"
            CanFilterColumns="False"
            CanReorderColumns="False"
            CornerButtonMode="None"
            DoubleTapped="EntryTable_DoubleTapped"
            FocusVisualPrimaryThickness="0"
            FocusVisualSecondaryThickness="0"
            HeadersVisibility="None"
            IsReadOnly="True"
            SelectionChanged="EntryTable_SelectionChanged"
            SelectionMode="Extended"
            SelectionUnit="Row"
            ShowExportOptions="False"
            UseSystemFocusVisuals="False"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
            ScrollViewer.HorizontalScrollMode="Disabled">
            <tv:TableView.Resources>
                <SolidColorBrush
                    x:Key="TableViewRowBackgroundSelected"
                    Color="{ThemeResource SystemAccentColor}"
                    Opacity="0.35" />
                <SolidColorBrush
                    x:Key="TableViewRowBackgroundSelectedPointerOver"
                    Color="{ThemeResource SystemAccentColor}"
                    Opacity="0.5" />
                <SolidColorBrush
                    x:Key="TableViewRowBackgroundSelectedPressed"
                    Color="{ThemeResource SystemAccentColor}"
                    Opacity="0.6" />
                <SolidColorBrush x:Key="TableViewRowFocusVisualPrimaryBrush" Color="Transparent" />
                <SolidColorBrush x:Key="TableViewRowFocusBorderBrush" Color="Transparent" />
            </tv:TableView.Resources>
            <tv:TableView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsStackPanel CacheLength="1.0" />
                </ItemsPanelTemplate>
            </tv:TableView.ItemsPanel>
            <tv:TableView.Columns>
                <tv:TableViewTemplateColumn Header="Name" SortMemberPath="Name" Width="320" MinWidth="100">
                    <tv:TableViewTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="fileEntryTable:SpecFileEntryViewModel">
                            <TextBlock Text="{x:Bind Name, Mode=OneTime}" Style="{StaticResource EllipsisTextCellStyle}" />
                        </DataTemplate>
                    </tv:TableViewTemplateColumn.CellTemplate>
                </tv:TableViewTemplateColumn>
                <tv:TableViewTextColumn Header="Ext" SortMemberPath="Extension" Binding="{Binding Extension}" Width="40" MinWidth="32" ElementStyle="{StaticResource MutedEllipsisCellStyle}" />
                <tv:TableViewTextColumn Header="Size" SortMemberPath="Size" Binding="{Binding Size}" Width="70" MinWidth="56" ElementStyle="{StaticResource RightAlignEllipsisCellStyle}" />
                <tv:TableViewDateColumn Header="Modified" SortMemberPath="Modified" Binding="{Binding Modified}" DateFormat="yyyy-MM-dd HH:mm:ss" Width="120" MinWidth="100" ElementStyle="{StaticResource EllipsisTextCellStyle}" />
                <tv:TableViewTextColumn Header="Attr" SortMemberPath="Attributes" Binding="{Binding Attributes}" Width="50" MinWidth="40" ElementStyle="{StaticResource MutedEllipsisCellStyle}" />
            </tv:TableView.Columns>
        </tv:TableView>
    </Grid>
</UserControl>
