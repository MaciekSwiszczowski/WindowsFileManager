<UserControl
    x:Class="WinUiFileManager.Presentation.Controls.FileInspector.InspectorToggleFieldView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>

    <Border Background="Transparent"
            PointerEntered="OnRowPointerEntered"
            PointerExited="OnRowPointerExited"
            ToolTipService.ToolTip="{x:Bind Field.Tooltip, Mode=OneWay}"
            Visibility="{x:Bind Field.IsVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
        <StackPanel Orientation="Horizontal">
            <TextBlock Width="88"
                       Padding="6,3"
                       Text="{x:Bind Field.Key, Mode=OneWay}"
                       FontSize="12"
                       TextWrapping="Wrap" />
            <ProgressRing Width="14"
                          Height="14"
                          Margin="6,3"
                          IsActive="True"
                          Visibility="{x:Bind Field.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
            <CheckBox MinWidth="32"
                      Padding="0"
                      VerticalAlignment="Center"
                      IsChecked="{x:Bind Field.IsToggleOn, Mode=TwoWay}"
                      IsEnabled="{x:Bind Field.CanInteract, Mode=OneWay}"
                      Command="{x:Bind Field.ToggleCommand, Mode=OneWay}" />
        </StackPanel>
    </Border>
</UserControl>
