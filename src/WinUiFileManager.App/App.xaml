<Application
    x:Class="WinUiFileManager.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="ms-appx:///Microsoft.UI.Xaml/DensityStyles/Compact.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="ListViewItemBackgroundSelected" Color="#3380A0FF" />
                    <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="#4480A0FF" />
                    <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPressed" Color="#5580A0FF" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="ListViewItemBackgroundSelected" Color="#440060D0" />
                    <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="#550060D0" />
                    <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPressed" Color="#660060D0" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
