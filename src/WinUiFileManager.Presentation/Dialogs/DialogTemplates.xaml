<ResourceDictionary
    x:Class="WinUiFileManager.Presentation.Dialogs.DialogTemplates"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="using:CommunityToolkit.WinUI.Behaviors"
    xmlns:interactivity="using:Microsoft.Xaml.Interactivity"
    xmlns:viewModels="using:WinUiFileManager.Presentation.ViewModels">

    <DataTemplate x:Key="RenameDialogDataTemplate" x:DataType="viewModels:RenameDialogViewModel">
        <Grid MinWidth="360" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock
                Grid.Row="0"
                Text="{Binding OriginalName, Mode=OneWay}"
                TextTrimming="CharacterEllipsis" />

            <TextBox
                x:Name="RenameNameBox"
                Grid.Row="1"
                Text="{Binding NewName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                <interactivity:Interaction.Behaviors>
                    <behaviors:FocusBehavior />
                    <behaviors:AutoSelectBehavior />
                </interactivity:Interaction.Behaviors>
            </TextBox>

            <TextBlock
                Grid.Row="2"
                Foreground="{ThemeResource SystemControlErrorTextForegroundBrush}"
                Text="{Binding ErrorMessage, Mode=OneWay}"
                TextWrapping="Wrap"
                Visibility="{Binding ErrorVisibility, Mode=OneWay}" />
        </Grid>
    </DataTemplate>

    <DataTemplate x:Key="MessageDialogDataTemplate" x:DataType="viewModels:MessageDialogViewModel">
        <TextBlock
            MinWidth="360"
            Text="{Binding Message, Mode=OneWay}"
            TextWrapping="Wrap" />
    </DataTemplate>
</ResourceDictionary>
