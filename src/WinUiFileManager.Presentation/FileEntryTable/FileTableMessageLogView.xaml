<UserControl
    x:Class="WinUiFileManager.Presentation.FileEntryTable.FileTableMessageLogView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid RowSpacing="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="Messages" FontWeight="SemiBold" />

        <ListView
            Grid.Row="1"
            ItemsSource="{x:Bind Entries, Mode=OneWay}"
            SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <TextBlock
                        Text="{Binding}"
                        FontFamily="Consolas"
                        FontSize="12"
                        TextWrapping="NoWrap" />
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>
