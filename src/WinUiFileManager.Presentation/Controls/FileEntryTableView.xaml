<UserControl
    x:Class="WinUiFileManager.Presentation.Controls.FileEntryTableView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:tv="using:WinUI.TableView"
    Loaded="FileEntryTableView_Loaded">
    <UserControl.Resources>
        <Style x:Key="EllipsisTextCellStyle" TargetType="TextBlock">
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="MutedEllipsisCellStyle" TargetType="TextBlock" BasedOn="{StaticResource EllipsisTextCellStyle}">
            <Setter Property="Foreground" Value="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
        </Style>
        <Style x:Key="RightAlignEllipsisCellStyle" TargetType="TextBlock" BasedOn="{StaticResource EllipsisTextCellStyle}">
            <Setter Property="HorizontalAlignment" Value="Right" />
        </Style>
    </UserControl.Resources>
    <tv:TableView
        x:Name="FileTable"
        ItemsSource="{Binding Items}"
        AutoGenerateColumns="False"
        IsReadOnly="True"
        SelectionMode="Extended"
        SelectionUnit="Row"
        CanReorderColumns="False"
        CanFilterColumns="False"
        ShowExportOptions="False"
        CornerButtonMode="None"
        HeadersVisibility="Columns"
        AllowLiveShaping="False"
        RowDoubleTapped="FileTable_RowDoubleTapped"
        Sorting="FileTable_Sorting"
        SelectionChanged="FileTable_SelectionChanged"
        KeyDown="FileTable_KeyDown"
        GotFocus="FileTable_GotFocus">
        <tv:TableView.Columns>
            <tv:TableViewTextColumn
                Header="Name"
                SortMemberPath="Name"
                Binding="{Binding Name}"
                MinWidth="100"
                Width="320"
                ElementStyle="{StaticResource EllipsisTextCellStyle}"
                CanSort="True" />
            <tv:TableViewTextColumn
                Header="Ext"
                SortMemberPath="Extension"
                Binding="{Binding Extension}"
                Width="40"
                MinWidth="32"
                ElementStyle="{StaticResource MutedEllipsisCellStyle}"
                CanSort="True" />
            <tv:TableViewTextColumn
                Header="Size"
                SortMemberPath="Size"
                Binding="{Binding Size}"
                Width="70"
                MinWidth="56"
                ElementStyle="{StaticResource RightAlignEllipsisCellStyle}"
                CanSort="True" />
            <tv:TableViewTextColumn
                Header="Modified"
                SortMemberPath="LastWriteTime"
                Binding="{Binding LastWriteTime}"
                Width="120"
                MinWidth="100"
                ElementStyle="{StaticResource EllipsisTextCellStyle}"
                CanSort="True" />
            <tv:TableViewTextColumn
                Header="Attr"
                SortMemberPath="Attributes"
                Binding="{Binding Attributes}"
                Width="50"
                MinWidth="40"
                ElementStyle="{StaticResource MutedEllipsisCellStyle}"
                CanSort="True" />
            <tv:TableViewTextColumn
                Header="FileId"
                SortMemberPath="FileId"
                Binding="{Binding FileId}"
                Width="100"
                MinWidth="72"
                ElementStyle="{StaticResource MutedEllipsisCellStyle}"
                CanSort="True" />
        </tv:TableView.Columns>
    </tv:TableView>
</UserControl>
