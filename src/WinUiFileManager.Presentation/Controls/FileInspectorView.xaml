<UserControl
    x:Class="WinUiFileManager.Presentation.Controls.FileInspectorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:fields="using:WinUiFileManager.Presentation.ViewModels.Inspector.Fields"
    xmlns:inspector="using:WinUiFileManager.Presentation.ViewModels.Inspector"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:viewModels="using:WinUiFileManager.Presentation.ViewModels">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <DataTemplate x:Key="NoSelectionTemplate" x:DataType="inspector:InspectorViewModel">
            <TextBlock HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                       Text="No files selected"
                       TextAlignment="Center" />
        </DataTemplate>

        <DataTemplate x:Key="MultiSelectionTemplate" x:DataType="inspector:InspectorViewModel">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="4">
                <TextBlock HorizontalAlignment="Center"
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                           Text="{x:Bind MultiSelectionStatusText, Mode=OneWay}"
                           TextAlignment="Center" />
                <TextBlock HorizontalAlignment="Center"
                           FontSize="12"
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                           Text="Inspector details are shown for a single item."
                           TextAlignment="Center" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="TextFieldTemplate" x:DataType="fields:InspectorFieldViewModel">
            <Border Background="Transparent"
                    PointerEntered="OnInspectorRowPointerEntered"
                    PointerExited="OnInspectorRowPointerExited"
                    ToolTipService.ToolTip="{x:Bind Tooltip, Mode=OneWay}"
                    Visibility="{x:Bind IsVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Width="88"
                               Padding="6,3"
                               Text="{x:Bind Key, Mode=OneWay}"
                               FontSize="12"
                               TextWrapping="Wrap" />
                    <ProgressRing Width="14"
                                  Height="14"
                                  Margin="6,3"
                                  IsActive="True"
                                  Visibility="{x:Bind IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <TextBlock Width="118"
                               Padding="6,3"
                               Text="{x:Bind DisplayValue, Mode=OneWay}"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="ThumbnailFieldTemplate" x:DataType="fields:InspectorThumbnailFieldViewModel">
            <Border Background="Transparent"
                    PointerEntered="OnInspectorRowPointerEntered"
                    PointerExited="OnInspectorRowPointerExited"
                    ToolTipService.ToolTip="{x:Bind Tooltip, Mode=OneWay}"
                    Visibility="{x:Bind IsVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Width="88"
                               Padding="6,3"
                               Text="{x:Bind Key, Mode=OneWay}"
                               FontSize="12"
                               TextWrapping="Wrap" />
                    <ProgressRing Width="14"
                                  Height="14"
                                  Margin="6,3"
                                  IsActive="True"
                                  Visibility="{x:Bind IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <Image Width="30"
                           Height="30"
                           Margin="6,3"
                           Source="{x:Bind ThumbnailSource, Mode=OneWay}"
                           Stretch="UniformToFill"
                           Visibility="{x:Bind ShowsThumbnail, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <TextBlock Width="118"
                               Padding="6,3"
                               Text="{x:Bind DisplayValue, Mode=OneWay}"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="Wrap"
                               Visibility="{x:Bind IsUnavailable, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="ToggleFieldTemplate" x:DataType="fields:InspectorToggleFieldViewModel">
            <Border Background="Transparent"
                    PointerEntered="OnInspectorRowPointerEntered"
                    PointerExited="OnInspectorRowPointerExited"
                    ToolTipService.ToolTip="{x:Bind Tooltip, Mode=OneWay}"
                    Visibility="{x:Bind IsVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Width="88"
                               Padding="6,3"
                               Text="{x:Bind Key, Mode=OneWay}"
                               FontSize="12"
                               TextWrapping="Wrap" />
                    <ProgressRing Width="14"
                                  Height="14"
                                  Margin="6,3"
                                  IsActive="True"
                                  Visibility="{x:Bind IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <CheckBox MinWidth="32"
                              Padding="0"
                              VerticalAlignment="Center"
                              IsChecked="{x:Bind IsToggleOn, Mode=TwoWay}"
                              IsEnabled="{x:Bind CanInteract, Mode=OneWay}"
                              Command="{x:Bind ToggleCommand, Mode=OneWay}" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="SingleSelectionTemplate" x:DataType="inspector:InspectorViewModel">
            <Grid RowSpacing="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" ColumnSpacing="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Text="Inspector" />
                    <Button Grid.Column="1"
                            Command="{x:Bind Commands.RefreshCommand}"
                            Content="Refresh" />
                    <Button Grid.Column="2"
                            Command="{x:Bind Commands.ShowPropertiesCommand}"
                            Content="Properties" />
                    <Button Grid.Column="3"
                            Command="{x:Bind Commands.CopyAllCommand}"
                            Content="Copy All" />
                </Grid>

                <TextBox Grid.Row="1"
                         PlaceholderText="Search property or value"
                         Text="{x:Bind SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <ScrollViewer Grid.Row="2"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">
                    <Grid MinWidth="250">
                        <ItemsRepeater ItemsSource="{x:Bind Categories, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <StackLayout Spacing="4" />
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="inspector:InspectorCategoryViewModel">
                                    <Expander Header="{x:Bind Name, Mode=OneWay}"
                                              Visibility="{x:Bind HasVisibleFields, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                              IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}"
                                              HorizontalAlignment="Stretch"
                                              HorizontalContentAlignment="Stretch">
                                        <ItemsRepeater ItemsSource="{x:Bind Fields, Mode=OneWay}">
                                            <ItemsRepeater.Layout>
                                                <StackLayout />
                                            </ItemsRepeater.Layout>
                                            <ItemsRepeater.ItemTemplate>
                                                <DataTemplate x:DataType="fields:InspectorFieldViewModel">
                                                    <TextBlock Text="{x:Bind Category}" />
                                                    <!-- <ContentControl x:Name="FieldContent" -->
                                                    <!--                 Content="{x:Bind}" -->
                                                    <!--                 ContentTemplate="{StaticResource TextFieldTemplate}"> -->
                                                    <!--     <i:Interaction.Behaviors> -->
                                                    <!--         <i:DataTriggerBehavior Binding="{x:Bind FieldTemplate, Mode=OneWay}" Value="Text"> -->
                                                    <!--             <i:ChangePropertyAction PropertyName="ContentTemplate" -->
                                                    <!--                                     TargetObject="{Binding ElementName=FieldContent}" -->
                                                    <!--                                     Value="{StaticResource TextFieldTemplate}" /> -->
                                                    <!--         </i:DataTriggerBehavior> -->
                                                    <!--         <i:DataTriggerBehavior Binding="{x:Bind FieldTemplate, Mode=OneWay}" Value="Thumbnail"> -->
                                                    <!--             <i:ChangePropertyAction PropertyName="ContentTemplate" -->
                                                    <!--                                     TargetObject="{Binding ElementName=FieldContent}" -->
                                                    <!--                                     Value="{StaticResource ThumbnailFieldTemplate}" /> -->
                                                    <!--         </i:DataTriggerBehavior> -->
                                                    <!--         <i:DataTriggerBehavior Binding="{x:Bind FieldTemplate, Mode=OneWay}" Value="Toggle"> -->
                                                    <!--             <i:ChangePropertyAction PropertyName="ContentTemplate" -->
                                                    <!--                                     TargetObject="{Binding ElementName=FieldContent}" -->
                                                    <!--                                     Value="{StaticResource ToggleFieldTemplate}" /> -->
                                                    <!--         </i:DataTriggerBehavior> -->
                                                    <!--     </i:Interaction.Behaviors> -->
                                                    <!-- </ContentControl> -->
                                                </DataTemplate>
                                            </ItemsRepeater.ItemTemplate>
                                        </ItemsRepeater>
                                    </Expander>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Border Padding="8"
            BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
            BorderThickness="1"
            Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <controls:SwitchPresenter TargetType="viewModels:FileInspectorSelectionMode"
                                  Value="{x:Bind ViewModel.SelectionMode, Mode=OneWay}">
            <controls:Case Value="NoSelection">
                <!-- <ContentControl Content="{x:Bind ViewModel, Mode=OneWay}" -->
                <!--                 ContentTemplate="{StaticResource NoSelectionTemplate}" /> -->
                <TextBlock Text="No selection" />
            </controls:Case>
            <controls:Case Value="SingleSelection">
                <!-- <ContentControl Content="{x:Bind ViewModel, Mode=OneWay}" -->
                <!--                 ContentTemplate="{StaticResource SingleSelectionTemplate}" /> -->
                <TextBlock Text="Single selection" />
            </controls:Case>
            <controls:Case Value="MultiSelection">
                <!-- <ContentControl Content="{x:Bind ViewModel, Mode=OneWay}" -->
                <!--                 ContentTemplate="{StaticResource MultiSelectionTemplate}" /> -->
                <TextBlock Text="Multi selection" />
            </controls:Case>
        </controls:SwitchPresenter>    
    </Border>
</UserControl>
