<UserControl
    x:Name="Root"
    x:Class="WinUiFileManager.Presentation.Controls.FileEntryTableView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="using:WinUiFileManager.Presentation.ViewModels"
    xmlns:tv="using:WinUI.TableView"
    Loaded="FileEntryTableView_Loaded">
    <UserControl.Resources>
        <Style x:Key="EllipsisTextCellStyle" TargetType="TextBlock">
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="MutedEllipsisCellStyle" TargetType="TextBlock" BasedOn="{StaticResource EllipsisTextCellStyle}">
            <Setter Property="Foreground" Value="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
        </Style>
        <Style x:Key="RightAlignEllipsisCellStyle" TargetType="TextBlock" BasedOn="{StaticResource EllipsisTextCellStyle}">
            <Setter Property="HorizontalAlignment" Value="Right" />
        </Style>
        <SolidColorBrush x:Key="TransparentTableFocusBrush" Color="Transparent" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <tv:TableView
            x:Name="HeaderTable"
            Grid.Row="0"
            ItemsSource="{x:Bind GridViewModel.ParentItems, Mode=OneWay}"
            AutoGenerateColumns="False"
            IsReadOnly="True"
            SelectionMode="Single"
            SelectionUnit="Row"
            FocusVisualPrimaryThickness="0"
            FocusVisualSecondaryThickness="0"
            CanReorderColumns="False"
            CanFilterColumns="False"
            ShowExportOptions="False"
            CornerButtonMode="None"
            HeadersVisibility="Columns"
            AllowLiveShaping="False"
            UseSystemFocusVisuals="False"
            Sorting="HeaderTable_Sorting"
            SelectionChanged="HeaderTable_SelectionChanged"
            PreviewKeyDown="HeaderTable_PreviewKeyDown"
            GotFocus="HeaderTable_GotFocus"
            LayoutUpdated="HeaderTable_LayoutUpdated"
            ScrollViewer.HorizontalScrollMode="Disabled"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
            ScrollViewer.VerticalScrollMode="Disabled"
            ScrollViewer.VerticalScrollBarVisibility="Hidden">
            <tv:TableView.Resources>
                <SolidColorBrush x:Key="TableViewRowBackgroundSelected"
                                 Color="{ThemeResource SystemAccentColor}"
                                 Opacity="0.35" />
                <SolidColorBrush x:Key="TableViewRowBackgroundSelectedPointerOver"
                                 Color="{ThemeResource SystemAccentColor}"
                                 Opacity="0.5" />
                <SolidColorBrush x:Key="TableViewRowBackgroundSelectedPressed"
                                 Color="{ThemeResource SystemAccentColor}"
                                 Opacity="0.6" />
                <SolidColorBrush x:Key="TableViewRowFocusVisualPrimaryBrush" Color="Transparent" />
                <SolidColorBrush x:Key="TableViewRowFocusBorderBrush" Color="Transparent" />
            </tv:TableView.Resources>
            <tv:TableView.Columns>
                <tv:TableViewTemplateColumn
                    x:Name="HeaderNameColumn"
                    Header="Name"
                    SortMemberPath="Name"
                    MinWidth="100"
                    Width="320"
                    IsReadOnly="True"
                    CanSort="True">
                    <tv:TableViewTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="viewModels:FileEntryViewModel">
                            <TextBlock
                                Text="{x:Bind Name, Mode=OneWay}"
                                Style="{StaticResource EllipsisTextCellStyle}" />
                        </DataTemplate>
                    </tv:TableViewTemplateColumn.CellTemplate>
                </tv:TableViewTemplateColumn>
                <tv:TableViewTemplateColumn
                    Header="Ext"
                    SortMemberPath="Extension"
                    Width="40"
                    MinWidth="32"
                    IsReadOnly="True"
                    CanSort="True">
                    <tv:TableViewTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="viewModels:FileEntryViewModel">
                            <TextBlock
                                Text="{x:Bind Extension, Mode=OneWay}"
                                Style="{StaticResource MutedEllipsisCellStyle}" />
                        </DataTemplate>
                    </tv:TableViewTemplateColumn.CellTemplate>
                </tv:TableViewTemplateColumn>
                <tv:TableViewTemplateColumn
                    Header="Size"
                    SortMemberPath="Size"
                    Width="70"
                    MinWidth="56"
                    IsReadOnly="True"
                    CanSort="True">
                    <tv:TableViewTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="viewModels:FileEntryViewModel">
                            <TextBlock
                                Text="{x:Bind Size, Mode=OneWay}"
                                Style="{StaticResource RightAlignEllipsisCellStyle}" />
                        </DataTemplate>
                    </tv:TableViewTemplateColumn.CellTemplate>
                </tv:TableViewTemplateColumn>
                <tv:TableViewTemplateColumn
                    Header="Modified"
                    SortMemberPath="LastWriteTime"
                    Width="120"
                    MinWidth="100"
                    IsReadOnly="True"
                    CanSort="True">
                    <tv:TableViewTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="viewModels:FileEntryViewModel">
                            <TextBlock
                                Text="{x:Bind LastWriteTime, Mode=OneWay}"
                                Style="{StaticResource EllipsisTextCellStyle}" />
                        </DataTemplate>
                    </tv:TableViewTemplateColumn.CellTemplate>
                </tv:TableViewTemplateColumn>
                <tv:TableViewTemplateColumn
                    Header="Attr"
                    SortMemberPath="Attributes"
                    Width="50"
                    MinWidth="40"
                    IsReadOnly="True"
                    CanSort="True">
                    <tv:TableViewTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="viewModels:FileEntryViewModel">
                            <TextBlock
                                Text="{x:Bind Attributes, Mode=OneWay}"
                                Style="{StaticResource MutedEllipsisCellStyle}" />
                        </DataTemplate>
                    </tv:TableViewTemplateColumn.CellTemplate>
                </tv:TableViewTemplateColumn>
            </tv:TableView.Columns>
        </tv:TableView>

        <tv:TableView
            x:Name="BodyTable"
            Grid.Row="1"
            ItemsSource="{x:Bind GridViewModel.Items, Mode=OneWay}"
            AutoGenerateColumns="False"
            IsReadOnly="False"
            SelectionMode="Extended"
            SelectionUnit="Row"
            FocusVisualPrimaryThickness="0"
            FocusVisualSecondaryThickness="0"
            CanReorderColumns="False"
            CanFilterColumns="False"
            ShowExportOptions="False"
            CornerButtonMode="None"
            HeadersVisibility="None"
            AllowLiveShaping="False"
            UseSystemFocusVisuals="False"
            BeginningEdit="BodyTable_BeginningEdit"
            SelectionChanged="BodyTable_SelectionChanged"
            PreparingCellForEdit="BodyTable_PreparingCellForEdit"
            CellEditEnding="BodyTable_CellEditEnding"
            CellEditEnded="BodyTable_CellEditEnded"
            PreviewKeyDown="BodyTable_PreviewKeyDown"
            KeyDown="BodyTable_KeyDown"
            GotFocus="BodyTable_GotFocus"
            ScrollViewer.HorizontalScrollMode="Disabled"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <tv:TableView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsStackPanel CacheLength="1.0" />
                </ItemsPanelTemplate>
            </tv:TableView.ItemsPanel>
            <tv:TableView.Resources>
                <SolidColorBrush x:Key="TableViewRowBackgroundSelected"
                                 Color="{ThemeResource SystemAccentColor}"
                                 Opacity="0.35" />
                <SolidColorBrush x:Key="TableViewRowBackgroundSelectedPointerOver"
                                 Color="{ThemeResource SystemAccentColor}"
                                 Opacity="0.5" />
                <SolidColorBrush x:Key="TableViewRowBackgroundSelectedPressed"
                                 Color="{ThemeResource SystemAccentColor}"
                                 Opacity="0.6" />
                <SolidColorBrush x:Key="TableViewRowFocusVisualPrimaryBrush" Color="Transparent" />
                <SolidColorBrush x:Key="TableViewRowFocusBorderBrush" Color="Transparent" />
            </tv:TableView.Resources>
            <tv:TableView.Columns>
                <tv:TableViewTemplateColumn
                    x:Name="BodyNameColumn"
                    Header="Name"
                    SortMemberPath="Name"
                    MinWidth="100"
                    Width="320"
                    IsReadOnly="False"
                    CanSort="False">
                    <tv:TableViewTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="viewModels:FileEntryViewModel">
                            <TextBlock
                                Text="{x:Bind Name, Mode=OneWay}"
                                Style="{StaticResource EllipsisTextCellStyle}" />
                        </DataTemplate>
                    </tv:TableViewTemplateColumn.CellTemplate>
                    <tv:TableViewTemplateColumn.EditingTemplate>
                        <DataTemplate x:DataType="viewModels:FileEntryViewModel">
                            <TextBox
                                Text="{Binding ElementName=Root, Path=GridViewModel.Host.EditBuffer, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                VerticalContentAlignment="Center"
                                IsSpellCheckEnabled="False" />
                        </DataTemplate>
                    </tv:TableViewTemplateColumn.EditingTemplate>
                </tv:TableViewTemplateColumn>
                <tv:TableViewTemplateColumn
                    Header="Ext"
                    SortMemberPath="Extension"
                    Width="40"
                    MinWidth="32"
                    IsReadOnly="True"
                    CanSort="False">
                    <tv:TableViewTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="viewModels:FileEntryViewModel">
                            <TextBlock
                                Text="{x:Bind Extension, Mode=OneWay}"
                                Style="{StaticResource MutedEllipsisCellStyle}" />
                        </DataTemplate>
                    </tv:TableViewTemplateColumn.CellTemplate>
                </tv:TableViewTemplateColumn>
                <tv:TableViewTemplateColumn
                    Header="Size"
                    SortMemberPath="Size"
                    Width="70"
                    MinWidth="56"
                    IsReadOnly="True"
                    CanSort="False">
                    <tv:TableViewTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="viewModels:FileEntryViewModel">
                            <TextBlock
                                Text="{x:Bind Size, Mode=OneWay}"
                                Style="{StaticResource RightAlignEllipsisCellStyle}" />
                        </DataTemplate>
                    </tv:TableViewTemplateColumn.CellTemplate>
                </tv:TableViewTemplateColumn>
                <tv:TableViewTemplateColumn
                    Header="Modified"
                    SortMemberPath="LastWriteTime"
                    Width="120"
                    MinWidth="100"
                    IsReadOnly="True"
                    CanSort="False">
                    <tv:TableViewTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="viewModels:FileEntryViewModel">
                            <TextBlock
                                Text="{x:Bind LastWriteTime, Mode=OneWay}"
                                Style="{StaticResource EllipsisTextCellStyle}" />
                        </DataTemplate>
                    </tv:TableViewTemplateColumn.CellTemplate>
                </tv:TableViewTemplateColumn>
                <tv:TableViewTemplateColumn
                    Header="Attr"
                    SortMemberPath="Attributes"
                    Width="50"
                    MinWidth="40"
                    IsReadOnly="True"
                    CanSort="False">
                    <tv:TableViewTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="viewModels:FileEntryViewModel">
                            <TextBlock
                                Text="{x:Bind Attributes, Mode=OneWay}"
                                Style="{StaticResource MutedEllipsisCellStyle}" />
                        </DataTemplate>
                    </tv:TableViewTemplateColumn.CellTemplate>
                </tv:TableViewTemplateColumn>
            </tv:TableView.Columns>
        </tv:TableView>
    </Grid>
</UserControl>
