<UserControl
    x:Class="WinUiFileManager.Presentation.Controls.FileInspector.InspectorCategoryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:fields="using:WinUiFileManager.Presentation.ViewModels.Inspector.Fields"
    xmlns:fileInspector="using:WinUiFileManager.Presentation.Controls.FileInspector">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <DataTemplate x:Key="BasicFieldTemplate"
                      x:DataType="fields:InspectorBasicFieldViewModel">
            <fileInspector:InspectorTextFieldView BasicField="{x:Bind}" />
        </DataTemplate>
        <DataTemplate x:Key="ThumbnailFieldTemplate"
                      x:DataType="fields:InspectorThumbnailFieldViewModel">
            <fileInspector:InspectorThumbnailFieldView Field="{x:Bind}" />
        </DataTemplate>
        <DataTemplate x:Key="ToggleFieldTemplate"
                      x:DataType="fields:InspectorToggleFieldViewModel">
            <fileInspector:InspectorToggleFieldView Field="{x:Bind}" />
        </DataTemplate>
    </UserControl.Resources>

    <!-- One Expander per category. Default expanded so an expert can scan every property at a glance; the user can
         collapse categories they don't care about. The Expander supplies the chevron, the click-to-toggle header, and
         the expand/collapse animation (nicer than a hand-rolled toggle). IsExpanded is two-way bound so the collapse
         state persists on the view model. The old Expander-vs-masonry overlap problem is gone: the parent
         AutoFillColumnsPanel is position-driven (not height-driven), and a child's expand/collapse changes its
         DesiredSize, which re-invalidates the panel so it re-packs the columns. Padding is zeroed so the body is as
         compact as the flat card was; the ItemsRepeater margin provides the inset. -->
    <Expander Visibility="{x:Bind Category.HasVisibleFields, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
              HorizontalAlignment="Stretch"
              HorizontalContentAlignment="Stretch"
              Padding="0"
              IsExpanded="{x:Bind Category.IsExpanded, Mode=TwoWay}">
        <Expander.Header>
            <!-- Category name plus the Debug-only per-handler profiling toggle (Active / Run-no-refresh / Inactive),
                 hidden in Release. The Button handles its own pointer, so tapping it does not toggle the Expander. -->
            <Grid HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           Style="{StaticResource BodyStrongTextBlockStyle}"
                           Text="{x:Bind Category.Name}" />
                <Button Grid.Column="1"
                        Margin="8,0,0,0"
                        Padding="8,2"
                        FontSize="11"
                        VerticalAlignment="Center"
                        Visibility="{x:Bind Category.ProfilingControlAvailable, Converter={StaticResource BoolToVisibilityConverter}}"
                        Command="{x:Bind Category.CycleProfilingModeCommand}"
                        Content="{x:Bind Category.ProfilingModeLabel, Mode=OneWay}"
                        ToolTipService.ToolTip="Profiling: cycle Active → Run without refreshing → Inactive" />
            </Grid>
        </Expander.Header>
        <!-- 4px side margin so a field's 6px cell padding lines up nicely inside the expander body. -->
        <ItemsRepeater Margin="4,4,4,6"
                       ItemsSource="{x:Bind Category.Fields, Mode=OneWay}"
                       HorizontalAlignment="Stretch">
            <ItemsRepeater.Layout>
                <StackLayout />
            </ItemsRepeater.Layout>
            <ItemsRepeater.ItemTemplate>
                <DataTemplate x:DataType="fields:InspectorFieldViewModelBase">
                    <controls:SwitchPresenter TargetType="fields:InspectorFieldType"
                                              HorizontalAlignment="Stretch"
                                              Value="{x:Bind FieldType, Mode=OneWay}">
                        <controls:Case Value="Text">
                            <ContentControl Content="{x:Bind}"
                                            ContentTemplate="{StaticResource BasicFieldTemplate}" />
                        </controls:Case>
                        <controls:Case Value="Thumbnail">
                            <ContentControl Content="{x:Bind}"
                                            ContentTemplate="{StaticResource ThumbnailFieldTemplate}" />
                        </controls:Case>
                        <controls:Case Value="Toggle">
                            <ContentControl Content="{x:Bind}"
                                            ContentTemplate="{StaticResource ToggleFieldTemplate}" />
                        </controls:Case>
                    </controls:SwitchPresenter>
                </DataTemplate>
            </ItemsRepeater.ItemTemplate>
        </ItemsRepeater>
    </Expander>
</UserControl>
