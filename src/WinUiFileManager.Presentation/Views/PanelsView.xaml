<UserControl
    x:Class="WinUiFileManager.Presentation.Views.PanelsView"
    x:Name="Self"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:WinUiFileManager.Presentation.Converters"
    xmlns:fileEntryTable="using:WinUiFileManager.Presentation.FileEntryTable"
    xmlns:messaging="using:WinUiFileManager.Presentation.Messaging"
    xmlns:i="using:Microsoft.Xaml.Interactivity"
    xmlns:toolkit="using:CommunityToolkit.WinUI.Controls">

    <UserControl.Resources>
        <converters:PixelGridLengthConverter x:Key="PixelGridLengthConverter" />
    </UserControl.Resources>

    <Grid ColumnSpacing="2" PreviewKeyDown="OnPreviewKeyDown">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="LeftPaneColumn"
                              Width="{x:Bind ViewModel.LeftPanelWidth, Mode=TwoWay, Converter={StaticResource PixelGridLengthConverter}}"
                              MinWidth="320" />
            <ColumnDefinition x:Name="LeftRightSplitterColumn" Width="6" />
            <ColumnDefinition x:Name="RightPaneColumn" Width="*" MinWidth="320" />
        </Grid.ColumnDefinitions>

        <Border x:Name="LeftPaneBorder"
                Grid.Column="0"
                BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1"
                Padding="4">
            <i:Interaction.Behaviors>
                <i:DataTriggerBehavior Binding="{x:Bind ViewModel.LeftPanel.IsActive, Mode=OneWay}" Value="True">
                    <i:ChangePropertyAction PropertyName="BorderBrush"
                                            TargetObject="{Binding ElementName=LeftPaneBorder}"
                                            Value="{ThemeResource SystemControlForegroundAccentBrush}" />
                    <i:ChangePropertyAction PropertyName="BorderThickness"
                                            TargetObject="{Binding ElementName=LeftPaneBorder}"
                                            Value="2" />
                </i:DataTriggerBehavior>
                <i:DataTriggerBehavior Binding="{x:Bind ViewModel.LeftPanel.IsActive, Mode=OneWay}" Value="False">
                    <i:ChangePropertyAction PropertyName="BorderBrush"
                                            TargetObject="{Binding ElementName=LeftPaneBorder}"
                                            Value="{ThemeResource SystemControlForegroundBaseLowBrush}" />
                    <i:ChangePropertyAction PropertyName="BorderThickness"
                                            TargetObject="{Binding ElementName=LeftPaneBorder}"
                                            Value="1" />
                </i:DataTriggerBehavior>
            </i:Interaction.Behaviors>
            <Grid RowSpacing="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" ColumnSpacing="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="104" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="LeftDrivePicker"
                              Grid.Column="0"
                              HorizontalAlignment="Stretch"
                              DisplayMemberPath="DriveLetter"
                              SelectionChanged="OnDriveSelectionChanged" />
                    <TextBox x:Name="LeftPathBox"
                             Grid.Column="1"
                             Text="{x:Bind ViewModel.LeftPanel.EditablePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             ToolTipService.ToolTip="{x:Bind ViewModel.LeftPanel.PathValidationMessage, Mode=OneWay}"
                             KeyDown="OnPathTextBoxKeyDown" />
                </Grid>
                <fileEntryTable:SpecFileEntryTableView x:Name="LeftEntryTable"
                                                       Grid.Row="1"
                                                       messaging:MessengerProperties.Messenger="{Binding Path=(messaging:MessengerProperties.Messenger), ElementName=Self, Mode=OneWay}" />
                <Border Grid.Row="2"
                        Height="24"
                        Padding="8,0"
                        VerticalAlignment="Stretch"
                        Background="{ThemeResource SystemControlBackgroundAltHighBrush}">
                    <TextBlock VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                               Text="{x:Bind ViewModel.LeftPanel.SummaryText, Mode=OneWay}" />
                </Border>
            </Grid>
        </Border>

        <toolkit:GridSplitter x:Name="PaneGridSplitter"
                              Grid.Column="1"
                              Background="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                              DragIncrement="8"
                              KeyboardIncrement="8"
                              ResizeBehavior="PreviousAndNext"
                              ResizeDirection="Columns" />

        <Border x:Name="RightPaneBorder"
                Grid.Column="2"
                BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1"
                Padding="4">
            <i:Interaction.Behaviors>
                <i:DataTriggerBehavior Binding="{x:Bind ViewModel.RightPanel.IsActive, Mode=OneWay}" Value="True">
                    <i:ChangePropertyAction PropertyName="BorderBrush"
                                            TargetObject="{Binding ElementName=RightPaneBorder}"
                                            Value="{ThemeResource SystemControlForegroundAccentBrush}" />
                    <i:ChangePropertyAction PropertyName="BorderThickness"
                                            TargetObject="{Binding ElementName=RightPaneBorder}"
                                            Value="2" />
                </i:DataTriggerBehavior>
                <i:DataTriggerBehavior Binding="{x:Bind ViewModel.RightPanel.IsActive, Mode=OneWay}" Value="False">
                    <i:ChangePropertyAction PropertyName="BorderBrush"
                                            TargetObject="{Binding ElementName=RightPaneBorder}"
                                            Value="{ThemeResource SystemControlForegroundBaseLowBrush}" />
                    <i:ChangePropertyAction PropertyName="BorderThickness"
                                            TargetObject="{Binding ElementName=RightPaneBorder}"
                                            Value="1" />
                </i:DataTriggerBehavior>
            </i:Interaction.Behaviors>
            <Grid RowSpacing="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" ColumnSpacing="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="104" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="RightDrivePicker"
                              Grid.Column="0"
                              HorizontalAlignment="Stretch"
                              DisplayMemberPath="DriveLetter"
                              SelectionChanged="OnDriveSelectionChanged" />
                    <TextBox x:Name="RightPathBox"
                             Grid.Column="1"
                             Text="{x:Bind ViewModel.RightPanel.EditablePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             ToolTipService.ToolTip="{x:Bind ViewModel.RightPanel.PathValidationMessage, Mode=OneWay}"
                             KeyDown="OnPathTextBoxKeyDown" />
                </Grid>
                <fileEntryTable:SpecFileEntryTableView x:Name="RightEntryTable"
                                                       Grid.Row="1"
                                                       messaging:MessengerProperties.Messenger="{Binding Path=(messaging:MessengerProperties.Messenger), ElementName=Self, Mode=OneWay}" />
                <Border Grid.Row="2"
                        Height="24"
                        Padding="8,0"
                        VerticalAlignment="Stretch"
                        Background="{ThemeResource SystemControlBackgroundAltHighBrush}">
                    <TextBlock VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                               Text="{x:Bind ViewModel.RightPanel.SummaryText, Mode=OneWay}" />
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
